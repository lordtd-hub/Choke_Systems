{
  "name": "choke-systems",
  "version": "0.1.0",
  "private": true,
  "description": "Contract-first schemas and validators for OBE-aligned course and weekly planning data.",
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "scripts": {
    "verify:machine": "npm run validate:contracts && npm run test:bundle && npm run test:analytics && npm run test:cqi-report && npm run test:dashboard-data && npm run test:course-dashboard-data && npm run test:course-dashboard-view && npm run test:catalog-dashboard-data && npm run test:catalog-dashboard-view && npm run test:course-workflow && npm run test:build-history && npm run test:output-registry && npm run test:course-action-queue && npm run test:control-status-summary && npm run test:system-output-registry && npm run test:publish-system-outputs && npm run test:build-control && npm run test:dashboard && npm run test:learning-record-store && npm run test:learning-record-services && npm run test:learning-record-projections && npm run test:learning-record-output-rewire",
    "validate:contracts": "node tools/validate-contracts.js calculus1_course.yaml calculus1_weekly_plan.yaml",
    "generate:module:week1": "node tools/build-interactive-module.js calculus1_course.yaml calculus1_weekly_plan.yaml 1",
    "validate:materials": "node tools/material-library.js",
    "validate:sbra": "node tools/sbra-blueprints.js",
    "build:bundle:week1": "node tools/build-week-bundle.js calculus1_course.yaml calculus1_weekly_plan.yaml 1",
    "run:demo:week3": "node tools/run-demo-week-workflow.js calculus1_course.yaml calculus1_weekly_plan.yaml 3",
    "run:demo:course": "node tools/run-demo-course-workflow.js calculus1_course.yaml calculus1_weekly_plan.yaml 1,2,3",
    "render:frontend:week3": "node tools/render-week-bundle-html.js calculus1_course.yaml calculus1_weekly_plan.yaml 3",
    "render:cqi:week3": "node tools/render-demo-cqi-report.js calculus1_course.yaml calculus1_weekly_plan.yaml 3",
    "test:contracts": "node tests/contract-validation.test.js",
    "test:module": "node tests/interactive-module.test.js",
    "test:bundle": "node tests/week-bundle.test.js",
    "test:runtime": "node tests/runtime-state.test.js",
    "test:assessment": "node tests/assessment-engine.test.js",
    "test:analytics": "node tests/analytics.test.js",
    "test:cqi-report": "node tests/cqi-report.test.js",
    "test:dashboard-data": "node tests/teacher-dashboard-data.test.js",
    "test:course-dashboard-data": "node tests/course-dashboard-data.test.js",
    "test:course-dashboard-view": "node tests/course-dashboard-view.test.js",
    "test:catalog-dashboard-data": "node tests/catalog-dashboard-data.test.js",
    "test:catalog-dashboard-view": "node tests/catalog-dashboard-view.test.js",
    "test:course-workflow": "node tests/course-workflow.test.js",
    "test:build-history": "node tests/build-history.test.js",
    "test:output-registry": "node tests/output-registry.test.js",
    "test:course-action-queue": "node tests/course-action-queue.test.js",
    "test:control-status-summary": "node tests/control-status-summary.test.js",
    "test:system-output-registry": "node tests/system-output-registry.test.js",
    "test:publish-system-outputs": "node tests/publish-system-outputs.test.js",
    "test:build-control": "node tests/instructor-build-control.test.js",
    "test:dashboard": "node tests/teacher-dashboard.test.js",
    "test:learning-record-store": "node tests/learning-record-store.test.js",
    "test:learning-record-services": "node tests/learning-record-services.test.js",
    "test:learning-record-projections": "node tests/learning-record-projections.test.js",
    "test:learning-record-output-rewire": "node tests/learning-record-output-rewire.test.js",
    "test:demo-workflow": "node tests/demo-workflow.test.js",
    "test:frontend": "node tests/frontend-contract-reader.test.js",
    "test:materials": "node tests/material-library.test.js",
    "test:material-authoring": "node tests/material-authoring.test.js",
    "test:persistence": "node tests/persistence.test.js",
    "test:sbra": "node tests/sbra-blueprints.test.js",
    "test:authoring": "node tests/sbra-authoring.test.js"
