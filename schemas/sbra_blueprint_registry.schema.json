{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/sbra_blueprint_registry.schema.json",
  "title": "SBRA Blueprint Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_version",
    "items"
  ],
  "properties": {
    "registry_version": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "activity_id",
          "blueprint_id",
          "file"
        ],
        "properties": {
          "activity_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "blueprint_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "file": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
