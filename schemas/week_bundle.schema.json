{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/week_bundle.schema.json",
  "title": "Week Bundle Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "interactive_module",
    "supplementary_materials",
    "sbra_payloads"
  ],
  "properties": {
    "interactive_module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_id",
        "course_id",
        "week",
        "title",
        "clo_focus",
        "learning_flow",
        "content_blocks",
        "activities",
        "progress_hooks",
        "assessment_hooks",
        "evidence_hooks"
      ],
      "properties": {
        "module_id": {
          "$ref": "#/$defs/idString"
        },
        "course_id": {
          "$ref": "#/$defs/idString"
        },
        "week": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "clo_focus": {
          "$ref": "#/$defs/cloMapping"
        },
        "learning_flow": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "section_id",
              "section_type",
              "block_refs",
              "activity_refs"
            ],
            "properties": {
              "section_id": {
                "$ref": "#/$defs/idString"
              },
              "section_type": {
                "type": "string",
                "enum": [
                  "intro",
                  "content",
                  "example",
                  "practice",
                  "sbra",
                  "quiz",
                  "reflection"
                ]
              },
              "block_refs": {
                "$ref": "#/$defs/idArray"
              },
              "activity_refs": {
                "$ref": "#/$defs/idArray"
              }
            }
          }
        },
        "content_blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "block_id",
              "type",
              "content",
              "clo_link"
            ],
            "properties": {
              "block_id": {
                "$ref": "#/$defs/idString"
              },
              "type": {
                "type": "string",
                "enum": [
                  "text",
                  "example",
                  "note"
                ]
              },
              "content": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "clo_link": {
                "$ref": "#/$defs/idString"
              }
            }
          }
        },
        "activities": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "activity_id",
              "type",
              "clo_mapping"
            ],
            "properties": {
              "activity_id": {
                "$ref": "#/$defs/idString"
              },
              "type": {
                "type": "string",
                "enum": [
                  "quiz",
                  "sbra",
                  "practice"
                ]
              },
              "clo_mapping": {
                "$ref": "#/$defs/cloMapping"
              }
            }
          }
        },
        "progress_hooks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_sections",
            "required_activities"
          ],
          "properties": {
            "required_sections": {
              "$ref": "#/$defs/idArray"
            },
            "required_activities": {
              "$ref": "#/$defs/idArray"
            }
          }
        },
        "assessment_hooks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "graded_activities"
          ],
          "properties": {
            "graded_activities": {
              "$ref": "#/$defs/idArray"
            }
          }
        },
        "evidence_hooks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "types"
          ],
          "properties": {
            "types": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "completion",
                  "score",
                  "reflection"
                ]
              }
            }
          }
        }
      }
    },
    "supplementary_materials": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "topic",
          "title",
          "description",
          "type",
          "tags",
          "addedDate"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "topic": {
            "type": "string",
            "enum": [
              "limits",
              "continuity",
              "differentiation",
              "integration",
              "shared"
            ]
          },
          "title": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "description": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "type": {
            "type": "string",
            "enum": [
              "pdf",
              "md",
              "html",
              "image",
              "video",
              "link",
              "note"
            ]
          },
          "path": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "url": {
            "type": "string",
            "pattern": "^https?://.+"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/nonEmptyString"
            }
          },
          "addedDate": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        }
      }
    },
    "sbra_payloads": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "activity_id",
          "name",
          "deliverable",
          "assessment_links",
          "evidence_tags",
          "clo_mapping",
          "rubric",
          "blueprint"
        ],
        "properties": {
          "activity_id": {
            "$ref": "#/$defs/idString"
          },
          "name": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "deliverable": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "assessment_links": {
            "$ref": "#/$defs/idArray"
          },
          "evidence_tags": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/nonEmptyString"
            }
          },
          "clo_mapping": {
            "$ref": "#/$defs/cloMapping"
          },
          "rubric": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/$defs/rubric"
              }
            ]
          },
          "blueprint": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/$defs/blueprint"
              }
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "idString": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "idArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/idString"
      }
    },
    "cloMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "secondary"
      ],
      "properties": {
        "primary": {
          "$ref": "#/$defs/idString"
        },
        "secondary": {
          "$ref": "#/$defs/idArray"
        }
      }
    },
    "rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rubric_id",
        "name",
        "applies_to",
        "criteria",
        "scoring_model"
      ],
      "properties": {
        "rubric_id": {
          "$ref": "#/$defs/idString"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "applies_to": {
          "$ref": "#/$defs/idArray"
        },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "criterion_id",
              "name",
              "description"
            ],
            "properties": {
              "criterion_id": {
                "$ref": "#/$defs/idString"
              },
              "name": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "description": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          }
        },
        "scoring_model": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "type",
            "levels"
          ],
          "properties": {
            "type": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "levels": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "number"
              }
            },
            "pass_threshold_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "xp_enabled": {
              "type": "boolean"
            },
            "xp_rule": {
              "type": "string"
            }
          }
        }
      }
    },
    "blueprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blueprint_id",
        "problem",
        "classification",
        "strategy",
        "steps",
        "full_solution",
        "misconception_map",
        "scoring"
      ],
      "properties": {
        "blueprint_id": {
          "$ref": "#/$defs/idString"
        },
        "problem": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "classification": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "topic",
            "type",
            "difficulty"
          ],
          "properties": {
            "topic": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "type": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "difficulty": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        },
        "strategy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "summary",
            "methods"
          ],
          "properties": {
            "summary": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "methods": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "step_no",
              "goal",
              "prompt",
              "options",
              "correct_option_id",
              "explanation"
            ],
            "properties": {
              "step_no": {
                "type": "integer",
                "minimum": 1
              },
              "goal": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "prompt": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "options": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "option_id",
                    "value",
                    "is_correct",
                    "error_type"
                  ],
                  "properties": {
                    "option_id": {
                      "$ref": "#/$defs/idString"
                    },
                    "value": {
                      "$ref": "#/$defs/nonEmptyString"
                    },
                    "is_correct": {
                      "type": "boolean"
                    },
                    "error_type": {
                      "$ref": "#/$defs/nonEmptyString"
                    }
                  }
                }
              },
              "correct_option_id": {
                "$ref": "#/$defs/idString"
              },
              "explanation": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          }
        },
        "full_solution": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "misconception_map": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "error_type",
              "description"
            ],
            "properties": {
              "error_type": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "description": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          }
        },
        "scoring": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "step_based"
          ],
          "properties": {
            "step_based": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
