{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/content_manifest.schema.json",
  "title": "Supplementary Content Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "items"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "topic",
          "title",
          "description",
          "type",
          "addedDate"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "topic": {
            "type": "string",
            "enum": [
              "limits",
              "continuity",
              "differentiation",
              "integration",
              "shared"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "type": {
            "type": "string",
            "enum": [
              "pdf",
              "md",
              "html",
              "image",
              "video",
              "link",
              "note"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "pattern": "^https?://.+"
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "addedDate": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "author": {
            "type": "string"
          },
          "duration": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "note"
                }
              },
              "required": [
                "type"
              ]
            },
            "then": {
              "required": [
                "body"
              ]
            }
          },
          {
            "oneOf": [
              {
                "required": [
                  "path"
                ],
                "not": {
                  "required": [
                    "url"
                  ]
                }
              },
              {
                "required": [
                  "url"
                ],
                "not": {
                  "required": [
                    "path"
                  ]
                }
              },
              {
                "properties": {
                  "type": {
                    "const": "note"
                  }
                },
                "required": [
                  "type",
                  "body"
                ],
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "path"
                      ]
                    },
                    {
                      "required": [
                        "url"
                      ]
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  }
}
